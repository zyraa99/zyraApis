            "url": "URL gambar yang ingin dihapus backgroundnya"
          }
        }
      ]
    },
    {
      "name": "Info",
      "icon": "fas fa-circle-info",
      "items": [
        {
          "name": "API Status",
          "desc": "Get API status, uptime",
          "path": "/api/status",
          "status": "ready"
        }
      ]
    }
  ]
}